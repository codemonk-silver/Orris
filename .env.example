# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EMAIL SMTP CONFIGURATION (For purchase confirmation emails)
# Support for production servers such as Resend, Postmark, or SendGrid:
# 
# RESEND:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465 or 587
#   SMTP_USER=resend
#   SMTP_PASS=re_your_api_key
# 
# POSTMARK:
#   SMTP_HOST=smtp.postmarkapp.com
#   SMTP_PORT=587
#   SMTP_USER=your_server_token
#   SMTP_PASS=your_server_token
# 
# SENDGRID:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your_api_key_here
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Orris Atelier <noreply@orris.com>

# STRIPE PAYMENT INTEGRATION
# Configure live Stripe hosted checkout sessions and signature checks:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PAYSTACK PAYMENT INTEGRATION
# Configure live Paystack payment sessions and callbacks:
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=


